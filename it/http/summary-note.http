### Basic request with no prescription and no follow-up

POST {{host}}/consultation/v1/summarization/submit HTTP/1.1
Accept: application/json
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {{doctorIdentity}}

{
  "appointmentId": "{{submitAppointmentId}}",
  "followUpInfo": {
    "__type": "NoFollowUp",
    "noteToStaff": "No follow-up needed"
  },
  "prescription": {
    "drugAllergyInfo": {
      "__type": "NoDrugAllergies"
    },
    "prescriptionItems": {
      "__type": "NoPrescription"
    }
  },
  "summaryNote": {
    "chiefComplaint": "Headache",
    "diagnosis": "Tension-type headache",
    "icd10": [
      {
        "code": "G44.2",
        "description": "Tension-type headache"
      }
    ],
    "illnessDuration": {
      "value": 2,
      "unit": "days"
    },
    "noteToStaff": "Follow up in 1 week if symptoms persist",
    "presentIllness": "Patient presents with persistent headache for 3 days",
    "recommendations": "Rest, hydration, and over-the-counter pain relief"
  }
}

### With prescription only

POST {{host}}/consultation/v1/summarization/submit HTTP/1.1
Accept: application/json
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {{doctorIdentity}}

{
  "appointmentId": "20260403100005",
