    "recommendations": "Rest and hydration"
  }
}

### With prescription + drug allergies

POST {{host}}/consultation/v1/summarization/submit HTTP/1.1
Accept: application/json
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {{doctorIdentity}}

{
  "appointmentId": "APT-DRUG-ALLERGY",
  "followUpInfo": {
    "__type": "NoFollowUp",
    "noteToStaff": null
  },
  "prescription": {
    "drugAllergyInfo": {
      "__type": "HasDrugAllergies",
      "drugAllergies": [
        {
          "id": 1,
          "displayText": "Penicillin"
        },
        {
          "id": 2,
          "displayText": "Sulfa drugs"
        }
      ]
    },
    "prescriptionItems": {
      "__type": "Prescription",
      "items": [
        {
          "pricePlanId": 4,
          "medicineId": 4,
          "medicineName": "Azithromycin 250mg",
          "dose": {
            "id": 1,
            "value": 250,
            "unit": "mg"
          },
          "quantity": 6,
          "route": {
            "id": 1,
            "description": "Oral"
          },
          "frequency": {
            "id": 1,
            "description": "Once a day"
          },
          "indication": {
            "id": 2,
            "description": "Bacterial infection"
          },
          "foodTiming": {
            "id": 2,
            "description": "Before meals"
          },
          "mealInstruction": {
            "id": 2,
            "description": "Take 1 hour before or 2 hours after meals"
          },
          "duration": {
            "id": 1,
            "value": 5,
            "unit": "days"
          },
          "cautions": "Patient allergic to Penicillin and Sulfa - safe alternative",
          "remark": "Day 1: 500mg, Days 2-5: 250mg",
          "noteToPatient": "Complete full 5-day course",
          "unitPrice": 12.0
        }
      ]
    }
  },
  "summaryNote": {
    "chiefComplaint": "Sinus infection",
    "diagnosis": "Acute bacterial sinusitis",
    "icd10": [
      {
        "code": "J01.9",
        "description": "Acute sinusitis, unspecified"
      }
    ],
    "illnessDuration": {
      "value": 10,
      "unit": "days"
    },
    "noteToStaff": "Patient has known Penicillin and Sulfa allergies - prescribed Azithromycin as alternative",
    "presentIllness": "Patient presents with 10 days of nasal congestion, facial pain, and purulent nasal discharge",
    "recommendations": "Complete antibiotic course, nasal saline irrigation, follow up if no improvement in 72 hours"
  }
}

### With follow-up only

POST {{host}}/consultation/v1/summarization/submit HTTP/1.1
Accept: application/json
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {{doctorIdentity}}

{
  "appointmentId": "20260403100001",
  "followUpInfo": {
    "__type": "ScheduleAppointment",
    "followStartDatetime": 1717430400,
    "followEndDatetime": 1717432200,
    "visitTypes": ["FollowUp"],
    "noteToPatient": "Please come back for follow-up in 2 weeks",
    "noteToStaff": "Monitor blood pressure"
  },
  "prescription": {
    "drugAllergyInfo": {
      "__type": "NoDrugAllergies"
    },
    "prescriptionItems": {
      "__type": "NoPrescription"
    }
  },
  "summaryNote": {
    "chiefComplaint": "Hypertension follow-up",
    "diagnosis": "Essential hypertension",
    "icd10": [
      {
        "code": "I10",
        "description": "Essential hypertension"
      }
    ],
    "illnessDuration": {
      "value": 30,
      "unit": "days"
    },
    "noteToStaff": null,
    "presentIllness": "Regular follow-up for blood pressure monitoring",
    "recommendations": "Continue current medication, monitor BP daily"
  }
}

### With all conditions (prescription + follow-up + complete summary)

POST {{host}}/consultation/v1/summarization/submit HTTP/1.1
Accept: application/json
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {{doctorIdentity}}

{
  "appointmentId": "{{submitAppointmentId}}",
  "followUpInfo": {
    "__type": "ScheduleAppointment",
    "followStartDatetime": 1718035200,
