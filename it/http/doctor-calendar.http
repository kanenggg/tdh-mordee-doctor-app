### BG doctor calendar update
### Edit raw event JSON in each Kulala pre-request script.
### The script encodes it into Pub/Sub message.data before sending.
### Run server-bg on {{bgHost}} (default http://localhost:8081).
### Sequence-dependent cases should be executed in file order.

### TimeslotReserved

< {%
  const event = {
    "__type": "TimeslotReserved",
    "bookingId": "bg-cal-reserve-cancel-1",
    "patientIdentity": {
      "accountId": 456,
      "userProfileId": 789,
      "tenantId": 1,
      "oidcUserId": "test-patient"
    },
    "doctorId": 123,
    "bizUnitId": 1,
    "reservedFrom": 1787965200,
    "reservationDurationSec": 1800,
    "consultationChannel": "video",
    "reservedAt": 1787965100
  };
  request.variables.set("messageData", Buffer.from(JSON.stringify(event)).toString("base64"));
%}

POST {{bgHost}}/consultation/v1/doctor-calendar/update HTTP/1.1
Accept: application/json
Content-Type: application/json

{
  "message": {
    "data": "{{messageData}}",
    "messageId": "timeslotreserved-{{$timestamp}}",
    "publishTime": "2026-06-24T00:00:00Z",
    "attributes": {}
  },
  "subscription": "doctor-calendar-update-sub"
}

