{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tdh.internal/contracts/schemas/doctor-profile-pull-response.schema.json",
  "title": "Doctor Profile Pub/Sub Pull Response",
  "type": "object",
  "required": ["receivedMessages"],
  "properties": {
    "receivedMessages": {
      "type": "array",
      "items": { "$ref": "#/$defs/receivedMessage" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "receivedMessage": {
      "type": "object",
      "required": ["ackId", "message"],
      "properties": {
        "ackId": { "type": "string", "minLength": 1 },
        "message": { "$ref": "#/$defs/pubsubMessage" },
        "deliveryAttempt": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "pubsubMessage": {
      "type": "object",
      "required": [
        "data",
        "attributes",
        "messageId",
        "orderingKey",
        "publishTime"
      ],
      "properties": {
        "data": {
          "type": "string",
          "minLength": 4,
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
          "contentEncoding": "base64",
          "contentMediaType": "application/json"
        },
        "attributes": { "$ref": "#/$defs/attributes" },
        "messageId": { "type": "string", "minLength": 1 },
        "orderingKey": { "type": "string", "pattern": "^[0-9]+$" },
        "publishTime": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "attributes": {
      "oneOf": [
        { "$ref": "#/$defs/approvedAttributes" },
        { "$ref": "#/$defs/statusUpdatedAttributes" }
      ]
    },
    "approvedAttributes": {
      "type": "object",
      "required": ["eventType", "eventId", "schemaVersion"],
      "properties": {
        "eventType": { "const": "DoctorProfileApproved" },
        "eventId": { "type": "string", "format": "uuid" },
        "schemaVersion": { "const": "2" }
      },
      "additionalProperties": { "type": "string" }
    },
    "statusUpdatedAttributes": {
      "type": "object",
      "required": ["eventType", "eventId", "schemaVersion"],
      "properties": {
        "eventType": { "const": "DoctorProfileStatusUpdated" },
        "eventId": { "type": "string", "format": "uuid" },
        "schemaVersion": { "const": "3" }
      },
      "additionalProperties": { "type": "string" }
    }
  }
}
