{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tdh.internal/contracts/schemas/doctor-profile-publish-request.schema.json",
  "title": "Doctor Profile Pub/Sub Publish Request",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/publishMessage" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "publishMessage": {
      "type": "object",
      "required": ["data", "attributes", "orderingKey"],
      "properties": {
        "data": {
          "type": "string",
          "minLength": 4,
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
          "contentEncoding": "base64",
          "contentMediaType": "application/json"
        },
        "attributes": { "$ref": "#/$defs/attributes" },
        "orderingKey": { "type": "string", "pattern": "^[0-9]+$" }
      },
      "additionalProperties": false
    },
    "attributes": {
      "oneOf": [
        { "$ref": "#/$defs/approvedAttributes" },
        { "$ref": "#/$defs/statusUpdatedAttributes" }
      ]
    },
    "approvedAttributes": {
      "type": "object",
      "required": ["eventType", "eventId", "schemaVersion"],
      "properties": {
        "eventType": { "const": "DoctorProfileApproved" },
        "eventId": { "type": "string", "format": "uuid" },
        "schemaVersion": { "const": "2" }
      },
      "additionalProperties": { "type": "string" }
    },
    "statusUpdatedAttributes": {
      "type": "object",
      "required": ["eventType", "eventId", "schemaVersion"],
      "properties": {
        "eventType": { "const": "DoctorProfileStatusUpdated" },
        "eventId": { "type": "string", "format": "uuid" },
        "schemaVersion": { "const": "3" }
      },
      "additionalProperties": { "type": "string" }
    }
  }
}
